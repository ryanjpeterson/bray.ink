brayink.ryanjpeterson.dev {
    # Supabase API (auth, storage, rest, functions) — strip /api prefix before forwarding to Kong
    handle_path /api/* {
        reverse_proxy kong:8000
    }

    # SvelteKit app
    handle {
        reverse_proxy app:3000
    }
}

# Local dev — only used when running docker compose locally
http://localhost:4000 {
    handle_path /api/* {
        reverse_proxy kong:8000
    }
    handle {
        reverse_proxy app:3000
    }
}

http://localhost:4001 {
    reverse_proxy studio:3000
}
