# Copy to .env and fill in values before running docker compose

# ── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_DB=postgres
POSTGRES_PASSWORD=change-me-strong-password

# ── Supabase secrets ───────────────────────────────────────────────────────
# Generate JWT_SECRET with: openssl rand -base64 32
# Then generate ANON and SERVICE_ROLE JWTs at: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
JWT_SECRET=change-me-jwt-secret-at-least-32-chars
SECRET_KEY_BASE=change-me-secret-key-base-64-chars
SUPABASE_ANON_KEY=your-generated-anon-jwt
SUPABASE_SERVICE_ROLE_KEY=your-generated-service-role-jwt

# ── Supabase Studio dashboard login ───────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-dashboard-password

# ── Domain — update both when you switch domains ──────────────────────────
# Current: brayink.ryanjpeterson.dev
# Future:  bray.ink
ORIGIN=https://brayink.ryanjpeterson.dev
SITE_URL=https://brayink.ryanjpeterson.dev
API_EXTERNAL_URL=https://brayink.ryanjpeterson.dev/api

# ── SvelteKit public env vars (baked into the client bundle at build time) ─
# Must be the public-facing URL the browser can reach Supabase at.
# Routed through Caddy: /api/* → kong:8000
PUBLIC_SUPABASE_URL=https://brayink.ryanjpeterson.dev/api
PUBLIC_SUPABASE_ANON_KEY=your-generated-anon-jwt

# ── Server-only Supabase URL (Docker internal — never changes) ────────────
SUPABASE_URL=http://kong:8000

# ── Upload limit ──────────────────────────────────────────────────────────
BODY_SIZE_LIMIT=11534336

# ── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
BOOKING_FORWARD_TO=brayinktats@gmail.com
BOOKING_FROM_EMAIL=bookings@brayink.ryanjpeterson.dev

# ── SMTP for Supabase Auth emails ─────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxx

# ── Instagram ─────────────────────────────────────────────────────────────
# Token is stored in the DB after OAuth — see supabase/INSTAGRAM_SETUP.md
