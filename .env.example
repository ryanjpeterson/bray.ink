# Copy to .env and fill in values before running docker compose

# ── Postgres ───────────────────────────────
POSTGRES_DB=postgres
POSTGRES_PASSWORD=change-me-strong-password

# ── Supabase secrets (generate with: openssl rand -base64 32) ──────────────
JWT_SECRET=change-me-jwt-secret-at-least-32-chars
SECRET_KEY_BASE=change-me-secret-key-base-64-chars
SUPABASE_ANON_KEY=your-generated-anon-jwt
SUPABASE_SERVICE_ROLE_KEY=your-generated-service-role-jwt

# ── Supabase URLs ──────────────────────────
API_EXTERNAL_URL=https://bray.ink/api
SITE_URL=https://bray.ink

# ── Supabase Studio dashboard login ───────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-dashboard-password

# ── App ────────────────────────────────────
ORIGIN=https://bray.ink

# ── SvelteKit public env vars (PUBLIC_ prefix required) ───────────────────
PUBLIC_SUPABASE_URL=http://localhost:8000
PUBLIC_SUPABASE_ANON_KEY=your-generated-anon-jwt

# ── Email (Resend) ─────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
BOOKING_FORWARD_TO=brayinktats@gmail.com
BOOKING_FROM_EMAIL=bookings@bray.ink

# ── SMTP for Supabase Auth emails (use Resend SMTP) ───────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxx

# ── Instagram ──────────────────────────────
# Seed this manually after OAuth: supabase/INSTAGRAM_SETUP.md
